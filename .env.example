TELEGRAM_TOKEN=your_telegram_bot_token

# Required by Nominatim — identify your bot (https://operations.osmfoundation.org/policies/nominatim/)
# NOMINATIM_USER_AGENT=WeatherPal/1.0 (your contact or repo URL)

# Optional: SQLite path (default: ./data/weatherpal.db)
# DATABASE_PATH=/data/weatherpal.db

# Optional: morning summaries & logs use server timezone
# TZ=Europe/London

# Optional: self-host Nominatim base URL
# NOMINATIM_BASE=https://nominatim.openstreetmap.org
